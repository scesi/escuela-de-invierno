---
import { fade } from 'astro:transitions';

const currentPath = Astro.url.pathname;
---

<header class="header-container">
    <nav class="nav-container" id="overlay">
        
    <div class="left-section">
      <a class="logo" href="/">
        Logo
      </a>
    </div>

    <div class="right-section">
      <button class="burger" id="burger" aria-label="Abrir menú" aria-expanded="false">
        <span class="line line1"></span>
        <span class="line line2"></span>
        <span class="line line3"></span>
    </button>

      <ul class="nav-links" id="navLinks">
          <li class="link"><a class={currentPath === "/" ? 'active' : ''} href="/" transition:animate={fade({ duration: '0.4s' })}>Home</a></li>
          <li class="link"><a class={currentPath === "/call-projects"? 'active' : ''} href="/call-projects" transition:animate={fade({ duration: '0.4s' })}>Llamado a Concurso de Proyectos de Graduacion</a></li>
      </ul>
    </div>
    </nav>

</header>

<script>
  function initBurgerMenu() {
    const burger = document.getElementById('burger');
    const nav = document.getElementById('navLinks');
    const lines = document.querySelectorAll('.line');
    if (!burger || !nav) return;

    burger.onclick = () => {
      const open = burger.classList.toggle('open');
      burger.setAttribute('aria-expanded', String(open));
      nav.classList.toggle('show'); 
      document.querySelector('.header-container')?.classList.toggle('show');
      document.querySelector('.logo')?.classList.toggle('show');
      lines.forEach(line => line.classList.toggle('show'));
    };
  }

  document.addEventListener('astro:page-load', initBurgerMenu);
  document.addEventListener('astro:after-swap', initBurgerMenu);
</script>
<style>
    .header-container{
        display: flex;
        justify-content: center;
        padding: 16px 32px;
        background-color: #fff;
        border-bottom: 1px solid rgba(172, 179, 194, .2);
        height: 48px;
        position: fixed;
        top: 0;
        width: 100%; 
        z-index: 2;
        transition: all .5s ease;
    }

   .nav-container{
        display: flex;
        justify-content: space-between;
        width: 80%;
        max-width: 980px;
        align-items: center;
    }

    .nav-links a{
        text-decoration: none;
        color: #333;
    }

    .nav-links{
        list-style: none;
        display: flex;
        gap: 20px;
    }
    .link{
        font-family: sans-serif, system-ui;
        font-weight: 600;
        font-size: 14px;
    }
    
    .link a:hover,
    .link a.active {
        color: #0070f3;
    }
    .logo{
        font-size: 30px;
        color:#000;
        text-decoration: none;
        font-weight: 900;
    }

    .burger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 6px;
        width: 44px;   
        height: 44px;
        padding: 0;
        background: none;
        border: none;
        cursor: pointer;
    }

    .line {
        width: 26px;
        height: 3px;
        background: #111;
        border-radius: 2px;
        transition: transform .25s ease, opacity .2s ease;
        transform-origin: center;
    }

    .burger.open .line1 { transform: translateY(9px) rotate(45deg); }
    .burger.open .line2 { opacity: 0; }
    .burger.open .line3 { transform: translateY(-9px) rotate(-45deg); }
    
    @media screen and (max-width: 820px) {
        .nav-container{
            display: flex;
            justify-content: space-between;
        }
        .burger {
            display: inline-flex;
        }

        .left-section,
        .right-section {
            display: flex;
            align-items: center;
        }
        .nav-links {
            position: fixed; 
            inset: 0;
            background: rgba(0,0,0,.9);
            flex-direction: column;
            align-items: start; 
            gap: 14px;
            transform: translateY(-100%);
            opacity: 0;
            transition: transform .3s ease, opacity .3s ease;
        }
        .header-container.show{
            background-color: #000;
        }
        .line.show{
            background-color: #fff;
        }
        .nav-links.show{
            transform: translateY(64.3px);
            opacity: 1;
        }
        .logo.show{
            color: #fff;
        }
        .nav-links a { color: #fff; font-size: 18px; }
    }

</style>
