---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
import burgerIcon from '../assets/burgerIcon.svg';

const currentPath = Astro.url.pathname;
---

<header class="header-container">
    <nav class="nav-container" id="overlay">
        
    <div class="left-section">
      <a href="/">
        <Image class="logo" src={logo} alt="Logo" width={120} height={40} />
      </a>
    </div>

    <div class="right-section">
      <button class="menu-toggle" id="burger" aria-label="Abrir menú" >
        <Image src={burgerIcon} alt="Menu Icon" width={40} height={40} />
      </button>

      <ul class="nav-links" id="navLinks">
          <li class="link"><a class={currentPath === "/" ? 'active' : ''} href="/" transition:animate="fade">Home</a></li>
          <li class="link"><a class={currentPath === "/call-projects"? 'active' : ''} href="/call-projects" transition:animate="fade">Llamado a Concurso de Proyectos de Graduacion</a></li>
      </ul>
    </div>
    </nav>

</header>

<style>
    .header-container{
        display: flex;
        justify-content: center;
        padding: 16px 32px;
        background-color: #fff;
        border-bottom: 1px solid rgba(172, 179, 194, .2);
        height: 48px;
        position: fixed;
        top: 0;
        width: 100%; 
        z-index: 2;
        transition: all .5s ease;
    }

   .nav-container{
        display: flex;
        justify-content: space-between;
        width: 80%;
        max-width: 980px;
        align-items: center;
    }

    .nav-links a{
        text-decoration: none;
        color: #333;
    }

    .nav-links{
        list-style: none;
        display: flex;
        gap: 20px;
    }
    .link{
        font-family: sans-serif, system-ui;
        font-weight: 600;
        font-size: 14px;
    }
    .logo {
        margin-left: -48px;
        width: 160px;
        height: auto;
    }
    .menu-close,
    .menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
    }
    .link a:hover,
    .link a.active {
        color: #0070f3;
    }


    @media screen and (max-width: 820px) {
        .nav-container{
            display: flex;
            justify-content: space-between;
        }
        .menu-toggle {
            display: block;
        }

        .left-section,
        .right-section {
        display: flex;
        align-items: center;
        }
        .nav-links {
            display: none;
            flex-direction: column;
            background: white;
            position: absolute;
            top: 56px;
            right: 32px;
            padding: 16px;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
        }

    }
</style>
